# JARVIS2026 Local Configuration
# Copy this to .env and fill in your values

# ===== App Settings =====
APP_NAME=JARVIS2026
APP_ENV=development
LOG_LEVEL=INFO

# ===== LLM Configuration =====
# Ollama must be running at this URL
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# Default models for MVP
OLLAMA_DIRECTOR_MODEL=qwen2.5:7b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
OLLAMA_DEFAULT_MODEL=qwen2.5:7b

# Model parameters
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40

# ===== Voice Settings =====
ENABLE_STT=false
ENABLE_TTS=false
ENABLE_WAKE_WORD=false
ENABLE_CLAP_DETECTION=false

# STT Provider (faster_whisper | vosk)
STT_PROVIDER=faster_whisper
WHISPER_MODEL=base

# TTS Provider (piper | pyttsx3)
TTS_PROVIDER=piper
PIPER_VOICE=en_US-hfc_female-medium
PIPER_SPEED=1.0

# ===== File System Paths =====
WORKSPACE_ROOT=./workspace
LOGS_DIR=./logs
DATA_DIR=./data

# Memory stores
MEMORY_DB_PATH=./memory/db/jarvis_memory.sqlite3
JOURNAL_PATH=./memory/journal
JOURNAL_FILE=daily_journal.md

# Audio data
AUDIO_INPUT_DIR=./data/audio/input
AUDIO_OUTPUT_DIR=./data/audio/output

# ===== Security & Permissions =====
# Max tokens per request
MAX_TOKENS_PER_REQUEST=2048

# Dangerous commands require approval
REQUIRE_APPROVAL_FOR_SHELL=true
REQUIRE_APPROVAL_FOR_GIT_COMMIT=true
REQUIRE_APPROVAL_FOR_FILE_DELETE=true

# Allowed workspace paths (comma-separated)
ALLOWED_WORKSPACE_PATHS=./workspace,./data

# ===== UI Settings =====
UI_WIDTH=1200
UI_HEIGHT=800
UI_THEME=dark
ORB_ANIMATION_SPEED=1.0

# ===== Agent Configuration =====
# Agent timeout in seconds
AGENT_TIMEOUT=60
AGENT_RETRY_ATTEMPTS=3

# Route keywords for agent selection
ROUTE_DEV_KEYWORDS=code,dev,fix,debug,test,python,function,class,bug,refactor
ROUTE_CTO_KEYWORDS=architecture,design,performance,scalability,infrastructure
ROUTE_BUSINESS_KEYWORDS=priority,roadmap,business,plan,client,revenue
ROUTE_NOTES_KEYWORDS=save,journal,memory,log,record,note,remember

# ===== Optional Integrations =====
# GitHub
GITHUB_TOKEN=
GITHUB_REPO=

# Browser automation
ENABLE_BROWSER_TOOLS=false
BROWSER_HEADLESS=true

# ===== Debug & Development =====
DEBUG=false
SHOW_PROMPTS=false
LOG_AGENT_DECISIONS=true
SAVE_CONVERSATIONS=true